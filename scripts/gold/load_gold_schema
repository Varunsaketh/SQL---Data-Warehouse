	-- In this layer what we are doing is merging these tables and giving thema detailed names for easy visulization 
	-- creted a veiw of this detailed query 
	-- it is a dimension table
	-- created a surraget key which will only exist in our database and has no meaning except for the uniqe indetifiction for our own easy understanding

	IF OBJECT_ID('gold.dim_customer_view','V') IS NOT NULL
	 DROP VIEW gold.dim_customer_view;

	CREATE OR ALTER VIEW gold.dim_customer_view AS
	SELECT
		ROW_NUMBER() OVER ( ORDER BY ci.cst_id) AS p_key,
		ci.cst_id AS customer_id,
		ci.cst_key AS customer_number,
		ci.cst_firstname AS first_name,
		ci.cst_lastname AS last_name,
		cu.BDATE AS birthday_date,
		lo.CNTRY AS country,
		ci.cst_marital_status AS marital_status,
		CASE 
			WHEN ci.cst_gndr != 'n/a' THEN ci.cst_gndr
			ELSE ISNULL(cu.GEN,'n/a')
		END AS gender,
		ci.cst_create_date AS create_date
	
		FROM Silver.crm_cust_info AS ci
		LEFT JOIN Silver.erp_cust_az12 as cu
		ON ci.cst_key = cu.CID
		LEFT JOIN Silver.erp_loc_a101 as lo
		ON ci.cst_key = lo.CID

