	IF OBJECT_ID('gold.dim_products_view','V') IS NOT NULL
	 DROP VIEW gold.dim_products_view;

	CREATE OR ALTER VIEW gold.dim_products_view AS
	SELECT 
	ROW_NUMBER() OVER(order by prd_id) AS p_key,
	pr.prd_id AS product_id,
	pr.cat_id AS category_id,
	pr.prd_key AS product_key,
	pr.prd_nm AS product_name,
	pr.prd_cost AS product_cost,
	pr.prd_line AS product_line,
	pr.prd_start_dt AS product_start_date,
	er.CAT AS category,
	er.SUBCAT AS sub_category,
	er.MAINTENANCE
	FROM Silver.crm_prd_info AS pr
	LEFT JOIN Silver.erp_px_cat_g1v2 as er
	ON pr.cat_id = er.id
	WHERE pr.prd_end_dt is null;

	SELECT
	*
	FROM gold.dim_products_view

	IF OBJECT_ID('gold.fact_sales_view','V') IS NOT NULL
	 DROP VIEW gold.fact_sales_view;

	-- for this final sales view it is a facts table as it contains multiple keys it states the the information about the otehr tables
	-- so we added our surrougate keys which we created in those tables 

	CREATE OR ALTER VIEW gold.fact_sales_view AS
	SELECT
	sd.sls_ord_num AS order_number,
	cv.p_key as customer_number,
	pv.p_key AS product_number,
	sd.sls_prd_key AS product_key,
	sd.sls_cust_id AS customer_id,
	sd.sls_order_dt AS order_date,
	sd.sls_ship_dt AS shipping_date,
	sd.sls_due_dt AS due_date,
	sd.sls_sales AS sales,
	sd.sls_quantity AS quantity,
	sd.sls_price AS price
	FROM Silver.crm_sales_details AS sd
	LEFT JOIN Gold.dim_customer_view as cv
	ON sd.sls_cust_id = cv.customer_id
	LEFT JOIN Gold.dim_products_view as pv
	ON sd.sls_prd_key = pv.product_key;

	SELECT
	*
	FROM gold.dim_customer_view;
	SELECT
	*
	FROM gold.dim_products_view;
	SELECT
	*
	FROM gold.fact_sales_view;

